# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Allowed origin for CORS (your extension ID or * for dev)
# Chrome extension origin format: chrome-extension://<EXTENSION_ID>
ALLOWED_ORIGIN=*

# Port for local development
PORT=3001

# Supabase (analytics) — get from your Supabase project settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Discord webhook URL for milestone + weekly summary notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Secret token for the cron endpoint (set same value in Vercel env + vercel.json headers)
CRON_SECRET=your-random-secret-here
